# Copy this file to .env and fill values
# Comma separated account aliases shown in dashboard
ACCOUNT_ALIASES=Self,Spouse,Parents

# Per-account credentials and tokens.
# IMPORTANT: Kite access_token usually expires daily. Update when needed.
# Example for account alias Self
SELF_API_KEY=
SELF_API_SECRET=
SELF_ACCESS_TOKEN=

# Example for account alias Spouse
SPOUSE_API_KEY=
SPOUSE_API_SECRET=
SPOUSE_ACCESS_TOKEN=

# Example for account alias Parents
PARENTS_API_KEY=
PARENTS_API_SECRET=
PARENTS_ACCESS_TOKEN=

# Optional: explicit DB path
DB_PATH=data/portfolio.db

# Dashboard refresh interval in hours
SYNC_INTERVAL_HOURS=12
