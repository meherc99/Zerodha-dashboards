# Add your Zerodha credentials here. Rename this file to '.env' so python-dotenv picks it up.
# The Dashboard will automatically pick up any user prefixed with API_KEY
# If no keys are provided, the dashboard will display a rich set of dummy data to show you how it looks.

# User 1 (e.g. Husband)
# HUSBAND_API_KEY="your_api_key_here"
# HUSBAND_API_SECRET="your_api_secret_here"
# HUSBAND_REQ_TOKEN="your_daily_request_token_here"

# User 2 (e.g. Wife)
# WIFE_API_KEY="your_api_key_here"
# WIFE_API_SECRET="your_api_secret_here"
# WIFE_REQ_TOKEN="your_daily_request_token_here"
